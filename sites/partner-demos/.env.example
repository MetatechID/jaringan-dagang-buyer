# Beli Aman demo storefronts — local-dev environment template.
# Copy to .env.local and fill in.

# Beli Aman BAP backend
NEXT_PUBLIC_BAP_URL=http://localhost:8003

# Firebase web SDK (get from Firebase console -> Project settings -> General -> Your apps -> Web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Random shared secret for the /admin demo cockpit. MUST match ADMIN_TOKEN on the BAP.
NEXT_PUBLIC_ADMIN_DEMO_TOKEN=dev-admin-token
